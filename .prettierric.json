{
  "arrowParens": "avoid",
  "printWidth": 300,
  "quoteProps": "preserve",
  "tabWidth": 4,
  "trailingComma": "none",
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", "*.yaml", "*.yml"],
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": ["*.config.js"],
      "options": {
        "printWidth": 150
      }
    }
  ]
}
